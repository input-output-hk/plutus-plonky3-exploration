              "$ref": "#/definitions/Int"
            },
            {
              "title": "x",
              "$ref": "#/definitions/Int"
            }
          ]
        }
      ]
    },
    "stark/proof/FriProof<goldilocks/ext2/Ext2>": {
      "title": "FriProof",
      "description": "The FRI opening proof (FriProof<Challenge, ChallengeMmcs, u64, InputProof>).\n\n commit_phase_commits:\n   One Merkle root per fold round (ChallengeMmcs::Commitment).\n   Length = number of FRI rounds (= degree_bits + log_blowup - log_final_poly_len - 1\n   with max_log_arity = 1 → 13 rounds for the Fibonacci proof).\n\n commit_pow_witnesses:\n   Per-round proof-of-work witnesses (u64). One per commit_phase_commit.\n   The verifier checks challenger.check_witness(commit_proof_of_work_bits, w).\n\n query_proofs:\n   One QueryProof per sampled query index.\n   Length = num_queries (= 100 in the production-like config).\n\n final_poly:\n   Low-degree polynomial sent in the clear as a list of Ext coefficients.\n   Length = 2^log_final_poly_len = 1 (a constant polynomial in the config).\n\n query_pow_witness:\n   Single proof-of-work witness for the query phase (checked after sampling\n   all commit-phase challenges and observing the final polynomial).",
      "anyOf": [
        {
          "title": "FriProof",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "commit_phase_commits",
